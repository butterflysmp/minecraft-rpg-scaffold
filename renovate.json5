{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:recommended'],

  // The dashboard is the point. A bot that opens zero PRs because everything is
  // current is indistinguishable from a bot that opens zero PRs because it is
  // misconfigured. The dashboard issue makes "what I found and what I am
  // holding" visible, so silence stops being ambiguous.
  dependencyDashboard: true,

  // Stated explicitly although it is the default. "Never auto-merge" is a
  // project rule (CLAUDE.md > Upgrade procedure), not a default to inherit
  // silently: the entire value of the PR is a human reading whether PacketEvents
  // supports the Minecraft drop.
  automerge: false,

  enabledManagers: ['maven'],

  packageRules: [
    {
      description: 'Default deny. Everything is opt-in, one dependency at a time.',
      matchPackageNames: ['*'],
      enabled: false,
    },

    {
      // PacketEvents is the GATE. CLAUDE.md's upgrade procedure is:
      //   1. check PacketEvents supports the new Minecraft drop  <-- the decision
      //   2. bump packetevents.version, confirm it builds
      //   3. bump paper.version
      // It lags a Minecraft release by 1-2 weeks. A bot opening this PR is how
      // you learn step 1's answer. Renovate updates the <properties> value that
      // ${packetevents.version} resolves from, not the reference.
      //
      // Plain semver, published to repo.codemc.io, which Renovate discovers from
      // the <repositories> block in the root pom. No custom versioning needed.
      description: 'PacketEvents is the upgrade gate. Open the PR; let a human read it.',
      matchDepNames: ['com.github.retrooper:packetevents-spigot'],
      enabled: true,
      automerge: false,
      addLabels: ['upgrade-gate'],
    },
  ],

  // ---------------------------------------------------------------------------
  // paper.version is DELIBERATELY NOT AUTOMATED. Do not "helpfully" add it.
  //
  // Two independent reasons.
  //
  // 1. Ordering. A PR on paper.version arrives at step 3 of the upgrade
  //    procedure above, before the step-1 information that decides whether to
  //    act on it at all. That is noise out of order, not automation. The gate
  //    opening is the signal; Paper's bump is what a human does afterwards.
  //
  // 2. The channel is not in the metadata. Versions look like
  //    26.1.2.build.74-stable and 26.2.build.53-alpha. That is not semver, and
  //    under Maven's ordering the alpha sorts ABOVE the stable release because
  //    numeric components compare first (26.2 > 26.1). A bot proposing an alpha
  //    is worse than no bot: it trains you to dismiss its PRs.
  //
  //    Renovate CAN encode the -stable/-alpha distinction, with regex versioning
  //    and a `compatibility` capture group -- compatibility partitions candidates,
  //    so a -stable pin would never be offered an -alpha. (It must be
  //    `compatibility`, not `prerelease`: a non-empty prerelease group marks the
  //    CURRENT version unstable, which unlocks alpha offers -- the exact poison.)
  //
  //    We do not do this. It would encode a Paper naming convention that lives
  //    in no authoritative place and breaks the day Paper changes the suffix.
  //    And a filter that has quietly stopped rejecting alphas looks exactly like
  //    a filter with nothing to reject -- the same shape as a test guard that
  //    passes because zero tests ran.
  //
  // gson is likewise excluded, for a different reason: it is `provided`. Paper
  // bundles it at runtime, so bumping the pom moves only the compile-time API
  // and can drift AHEAD of what the server actually runs. Pin it by hand to
  // match Paper.
  // ---------------------------------------------------------------------------
}
